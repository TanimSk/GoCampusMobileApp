        {
          "name": "login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.role == \"ADMIN\")",
                  "    // Store access token as a collection variable",
                  "    pm.collectionVariables.set(\"accessTokenAdmin\", `${response.access}`);",
                  "",
                  "if (response.role == \"STUDENT\")",
                  "    // Store access token as a collection variable",
                  "    pm.collectionVariables.set(\"accessTokenStudent\", `${response.access}`);",
                  "",
                  "",
                  "if (response.role == \"ECART\")",
                  "    // Store access token as a collection variable",
                  "    pm.collectionVariables.set(\"accessTokenEcart\", `${response.access}`);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"id\": \"2310876102\",\n    \"password\": \"123456\"\n}",
